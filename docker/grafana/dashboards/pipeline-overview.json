{
  "title": "Trypto Collector Pipeline",
  "uid": "collector-pipeline",
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 100,
      "title": "📡 Throughput",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "title": "거래소별 발행 rate (msg/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "maxDataPoints": 2880,
      "targets": [
        {
          "expr": "rate(rabbitmq_publish_total[1m])",
          "legendFormat": "{{exchange}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msg/s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "title": "전체 합산 발행 rate (msg/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "maxDataPoints": 2880,
      "targets": [
        {
          "expr": "sum(rate(rabbitmq_publish_total[1m]))",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msg/s",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 17,
      "title": "거래소별 Throughput 통계",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(rate(rabbitmq_publish_total[1m])[$__range:1m])",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "quantile_over_time(0.5, rate(rabbitmq_publish_total[1m])[$__range:1m])",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "max_over_time(rate(rabbitmq_publish_total[1m])[$__range:1m])",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "instance": true, "job": true },
            "indexByName": { "exchange": 0, "Value #A": 1, "Value #B": 2, "Value #C": 3 },
            "renameByName": { "exchange": "Exchange", "Value #A": "mean", "Value #B": "median", "Value #C": "max" }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "msg/s", "decimals": 1 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Exchange" },
            "properties": [
              { "id": "unit", "value": "string" },
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      }
    },
    {
      "id": 18,
      "title": "전체 Throughput 통계",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(sum(rate(rabbitmq_publish_total[1m]))[$__range:1m])",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "quantile_over_time(0.5, sum(rate(rabbitmq_publish_total[1m]))[$__range:1m])",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "max_over_time(sum(rate(rabbitmq_publish_total[1m]))[$__range:1m])",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "instance": true, "job": true },
            "indexByName": { "Value #A": 0, "Value #B": 1, "Value #C": 2 },
            "renameByName": { "Value #A": "mean", "Value #B": "median", "Value #C": "max" }
          }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "msg/s", "decimals": 1 } }
    },
    {
      "id": 300,
      "title": "🚨 Errors & Reliability",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }
    },
    {
      "id": 7,
      "title": "WebSocket 재연결",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(websocket_reconnect_total[5m])",
          "legendFormat": "{{exchange}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 9,
      "title": "RabbitMQ NACK",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(rabbitmq_nack_count_total[5m])",
          "legendFormat": "RabbitMQ NACK"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 }
        }
      }
    },
    {
      "id": 400,
      "title": "🧹 GC",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }
    },
    {
      "id": 11,
      "title": "GC 로 멈춘 시간 비율",
      "description": "1초당 GC 로 멈춰 있던 시간. 0.05 = 5% 를 멈춰 있었다는 뜻. 지속적으로 높으면 시세 전달이 상시 밀리고 있다.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=\"collector\"}[1m])",
          "legendFormat": "{{action}} ({{cause}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 12,
      "title": "한 번에 가장 오래 멈춘 시간",
      "description": "단일 GC 멈춤의 최대치. '가끔 시세가 확 튄다'는 증상의 범인은 평균이 아니라 이 값이다.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_gc_pause_seconds_max{job=\"collector\"}",
          "legendFormat": "{{action}} ({{cause}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "schemaVersion": 39
}
