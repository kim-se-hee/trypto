-- 송금 내역 조회(GET /api/wallets/{walletId}/transfers) 부하테스트용 시드 템플릿.
-- reset.sh 가 transfer_history.js 시나리오일 때 @WALLET_COUNT@ / @TRANSFERS_PER_WALLET@ 를 치환해 렌더한다.
--
-- 선행:
--   loadtest.sql → coin / exchange_market(1=UPBIT) / user / investment_round(ACTIVE) /
--                  wallet(1~@WALLET_COUNT@) 적재. wallet w 는 round w, user w 와 1:1.
--
-- 조회 경로(TransferQueryAdapter.findByCursor)가 밟는 쿼리:
--   ALL      WHERE (from_wallet_id=? OR to_wallet_id=?) AND id < ? ORDER BY id DESC LIMIT ?
--   DEPOSIT  WHERE to_wallet_id=?   AND id < ? ...
--   WITHDRAW WHERE from_wallet_id=? AND id < ? ...
-- transfer 테이블에는 PK(transfer_id) + UNIQUE(idempotency_key) 외 보조 인덱스가 없다
-- (엔티티에 @Index 미선언 = 운영과 동일). OR 조건이 풀스캔 + filesort 로 떨어지는
-- 무인덱스 상태를 그대로 측정하기 위해 여기서도 인덱스를 만들지 않는다.
--
-- 적재 규모: @WALLET_COUNT@ 지갑 × 지갑당 출금 @TRANSFERS_PER_WALLET@ 건.
--   transfer_id = (w-1) * @TRANSFERS_PER_WALLET@ + s    (w: 1..N, s: 1..K)
--   from_wallet = w, to_wallet = (w % N) + 1            (w 의 다음 지갑으로 보낸다)
--   → 지갑 w 의 조회 이력 = 출금 K(자기 발신) + 입금 K(앞 지갑 수신) ≈ 2K 행.
--   idempotency_key 는 transfer_id 로 결정해 BINARY(16) 유니크를 채운다.
--   status 는 SUCCESS 만 — TransferStatus enum 에 SUCCESS 외 값이 없어 다른 값은 조회 시
--   toDomain() enum 매핑에서 깨진다. completed_at 은 created_at 과 같게 둔다.

SET SESSION cte_max_recursion_depth = 1000000;

INSERT INTO transfer
  (transfer_id, idempotency_key, from_wallet_id, to_wallet_id,
   coin_id, amount, status, created_at, completed_at)
WITH RECURSIVE
  w AS (SELECT 1 AS n UNION ALL SELECT n + 1 FROM w WHERE n < @WALLET_COUNT@),
  s AS (SELECT 1 AS k UNION ALL SELECT k + 1 FROM s WHERE k < @TRANSFERS_PER_WALLET@)
SELECT
  (w.n - 1) * @TRANSFERS_PER_WALLET@ + s.k                                       AS transfer_id,
  UNHEX(LPAD(HEX((w.n - 1) * @TRANSFERS_PER_WALLET@ + s.k), 32, '0'))           AS idempotency_key,
  w.n                                                                            AS from_wallet_id,
  (w.n % @WALLET_COUNT@) + 1                                                     AS to_wallet_id,
  2 + (s.k % 10)                                                                 AS coin_id,
  (0.001 + (s.k % 100) * 0.0001)                                                 AS amount,
  'SUCCESS'                                                                       AS status,
  DATE_SUB(NOW(), INTERVAL ((w.n - 1) * @TRANSFERS_PER_WALLET@ + s.k) MINUTE)    AS created_at,
  DATE_SUB(NOW(), INTERVAL ((w.n - 1) * @TRANSFERS_PER_WALLET@ + s.k) MINUTE)    AS completed_at
FROM w CROSS JOIN s;
