# 백엔드 소셜 OAuth 시크릿. 실제 값은 .env 에 넣는다(커밋 금지).
# docker-compose 가 이 파일과 같은 위치의 .env 를 읽어 backend 컨테이너에 주입한다.
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
