#!/bin/sh
# 커밋 메시지에 Co-Authored-By 트레일러를 차단한다.
# 근거: docs/git-convention.md '금지 사항' — AI 생성 서명을 포함하지 않는다.

if grep -qE '^Co-Authored-By:' "$1"; then
  echo "ERROR: Co-Authored-By 트레일러는 사용할 수 없습니다." >&2
  echo "       근거: docs/git-convention.md '금지 사항'" >&2
  echo "       메시지에서 'Co-Authored-By:' 로 시작하는 라인을 모두 제거한 뒤 다시 커밋하세요." >&2
  exit 1
fi
